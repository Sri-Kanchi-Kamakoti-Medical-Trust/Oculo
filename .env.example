# Copy to .env and adjust as needed. The core training pipeline needs NO API keys.
# .env is gitignored; never commit real secrets.

# Directory of preprocessed {image_id}.png images (output of src/preprocess.py)
OCULO_IMG_DIR=data/images

# Directory containing foundation-model weights (see docs/foundation_models.md)
OCULO_PRETRAINED_DIR=pretrained

# Optional: Hugging Face token, only if downloading the dataset programmatically
# HF_TOKEN=
